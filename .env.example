# Site URL for metadata (Open Graph, canonical)
NEXT_PUBLIC_SITE_URL=https://1320soulcode.com

# Optional — Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Log analytics events in production (debug only)
# NEXT_PUBLIC_ANALYTICS_DEBUG=false

# Log calculator submit steps to browser console (for mobile QA)
# NEXT_PUBLIC_DEBUG_CALCULATOR=true

# Optional — POST JSON lead payloads (waitlist, email, booking)
# LEADS_WEBHOOK_URL=https://your-webhook.example/leads
