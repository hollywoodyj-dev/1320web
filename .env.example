# Site URL for metadata (Open Graph, canonical) + Stripe redirect URLs
NEXT_PUBLIC_SITE_URL=https://1320soulcode.com

# Optional — Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Log analytics events in production (debug only)
# NEXT_PUBLIC_ANALYTICS_DEBUG=false

# Log calculator submit steps to browser console (for mobile QA)
# NEXT_PUBLIC_DEBUG_CALCULATOR=true

# Show report debug panel (resolved keys, combination signature)
# NEXT_PUBLIC_REPORT_DEBUG=true

# --- Phase 2A: database (Neon / Vercel Postgres) ---
# POSTGRES_URL=postgresql://user:pass@host/db?sslmode=require

# --- Phase 2A: Stripe one-time Full Report checkout ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_FULL_REPORT_AMOUNT_CENTS=4900
# Or use a Stripe Price ID (price_..., NOT prod_...) instead of amount:
# STRIPE_FULL_REPORT_PRICE_ID=price_...

# --- Phase 2A: magic-link email (optional; logs link in dev if unset) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM=1320 Soul Code <noreply@1320soulcode.com>

# Deprecated — Phase 2A uses POSTGRES_URL instead of webhook forwarding
# LEADS_WEBHOOK_URL=https://your-webhook.example/leads
